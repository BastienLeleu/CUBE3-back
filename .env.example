# ==========================================
# CUBE3 - Fichier d'exemple de configuration
# ==========================================
# Copiez ce fichier en '.env' et remplacez les valeurs par vos secrets.
# Le fichier '.env' est ignoré par Git pour des raisons de sécurité.

# --- Base de données PostgreSQL ---
POSTGRES_USER=collector
POSTGRES_PASSWORD=change_me_in_prod_postgres_secret
POSTGRES_DB=collector_db

# --- Backend NestJS ---
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://collector:change_me_in_prod_postgres_secret@postgres:5432/collector_db
JWT_SECRET=change_me_in_prod_jwt_super_secret_key_2026!
CORS_ORIGIN=http://localhost:4200

# --- Paramètres DB & Seeding ---
DB_SYNCHRONIZE=true
# En production (NODE_ENV=production), le seeder est désactivé par sécurité.
# Mettre FORCE_SEEDING=true (ou ENABLE_SEEDING=true) uniquement si vous souhaitez forcer le seeding en production.
FORCE_SEEDING=false
# ENABLE_SEEDING=false

# --- Identifiants de Seeding par défaut ---
ADMIN_DEFAULT_EMAIL=admin@collector.shop
ADMIN_DEFAULT_PASSWORD=ChangeMeInProd!123
SELLER_DEFAULT_PASSWORD=ChangeMeInProd!123

# --- Supervision Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_in_prod_grafana_password
